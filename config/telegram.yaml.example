# config/telegram.yaml.example
bot_token: "PUT_TELEGRAM_BOT_TOKEN"
owner_chat_id: "PUT_OWNER_CHAT_ID"
tone: "partner"
buttons:
  approve: "✅ Утвердить"
  rework: "🔁 Доработать"
  clarify: "❓ Уточнить"
  full: "📄 Полный отчёт"
  dashboard: "📊 Панель"
  merged: "✅ Я смержил"
callbacks:
  approve: "a:{task_id}"
  rework: "r:{task_id}"
  clarify: "c:{task_id}"
  full: "f:{task_id}"
