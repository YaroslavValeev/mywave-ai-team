# Локальный запуск без Docker — раскомментируй для SQLite:
# DATABASE_URL=sqlite:///./mywave.db
# В Docker — DATABASE_URL не нужен (используется Postgres из compose)

TELEGRAM_BOT_TOKEN=
OWNER_CHAT_ID=
POSTGRES_PASSWORD=mywave_secret_change_me

# HF-1: обязателен для Dashboard (fail-fast без него)
OWNER_API_KEY=your_secret_key_change_me

# Опционально
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mywave
POSTGRES_DB=mywave_ai
# Production: https://agm.mywavewake.ru (для ссылок в Telegram)
DASHBOARD_URL=https://agm.mywavewake.ru
# DASHBOARD_API_KEY=  # deprecated, используй OWNER_API_KEY
OPENAI_API_KEY=
# Smart Intake v0: опционально один JSON-вызов к OpenAI для классификации (иначе rule-based)
INTAKE_USE_LLM=false
# INTAKE_LLM_MODEL=gpt-4o-mini
# TTL pending-кнопок в памяти процесса Telegram-бота (секунды)
INTAKE_PENDING_TTL_SEC=900
# Smart Intake v1: контекст проекта/задачи и память (Postgres MemoryEntry)
INTAKE_V1=true
# Порог схожести текста с открытой задачей (0–1) для attach без реплая
INTAKE_ATTACH_SIMILARITY_THRESHOLD=0.26
# Запись MemoryEntry после завершения оркестрации
INTAKE_MEMORY_WRITE=true
# Owner Memory / Rules Layer (YAML+БД): intake + оркестрация; миграция 005 на Postgres
OWNER_MEMORY_ENABLED=true
OWNER_MEMORY_AUTO_SEED=true
# Запись tier=inferred из движка (по умолчанию выкл.)
OWNER_MEMORY_INFERRED_WRITE=false
# GM / Director Layer: режим исполнения после Intake + Owner Memory (без отдельного LLM)
GM_DIRECTOR_ENABLED=true
ARTIFACTS_DIR=app/artifacts
# Канон профилей: docs/CANONICAL-RUNTIME.md (office-full vs office-lite).
# Локально / dev: часто auto + полный requirements.txt.
# Docker: DOCKER_BUILD_TARGET=lite|full (см. docker-compose.yml).
ORCHESTRATION_ENGINE=auto
ORCHESTRATION_ALLOW_FALLBACK=true
# --- LLM tiers (ADR-006): local = RU Ollama; cloud = EU LiteLLM → OpenAI ---
LLM_TIER_DEFAULT=local
# LLM_LOCAL_BASE_URL=http://ollama:11434/v1
# LLM_LOCAL_API_KEY=ollama
# LLM_LOCAL_MODEL=llama3.2:3b
# LLM_CLOUD_BASE_URL=http://72.56.99.214:4000/v1
# LLM_CLOUD_API_KEY=  # LITELLM_MASTER_KEY с EU (не sk-proj OpenAI)
# LLM_CLOUD_MODEL=gpt-4.1-nano
# Owner: #CLOUD / #OPENAI в тексте или кнопки «OpenAI (EU)» / «Локально» в TG.
# Модель для ролей (legacy / fallback имени); tier overrides выше приоритетнее.
CREWAI_MODEL=gpt-4.1-nano
CREWAI_DEFAULT_MODEL=gpt-4.1-nano
CREWAI_PROVIDER=openai
CREWAI_TEMPERATURE=0.2
CREWAI_TIMEOUT=120
CREWAI_MAX_TOKENS=2000
CREWAI_USE_RESPONSES_API=false
# Локальный OpenAI-compatible (Ollama / LM Studio) — приоритет экономии токенов:
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# (без /v1 код сам допишет /v1; из Docker к хосту: http://host.docker.internal:11434)
# OPENAI_API_KEY=ollama
# CREWAI_MODEL=llama3.2
# CREWAI_PROVIDER=openai
# Если OPENAI_BASE_URL пуст — используется облачный OPENAI_API_KEY.
# RU: облачный OpenAI часто недоступен без прокси — используйте LLM_CLOUD_* → EU LiteLLM.
TELEGRAM_RETRY_ATTEMPTS=4
TELEGRAM_RETRY_BASE_SECONDS=1.5
# Короткие TG-уведомления на границах этапов (триаж/конвейер/совещание/суд). 0=выкл.
TELEGRAM_STAGE_NOTIFY=true

# --- Molt on RU (OPTIONAL, Owner GO only) ---
# App → Molt HTTP (in-compose: http://molt:8765; on host smoke: http://127.0.0.1:8765)
# MOLT_HTTP_BASE_URL=http://molt:8765
# MOLT_TRANSPORT_MODE=http
# CANONICAL_PATH_ENABLED=0
# CANONICAL_STORAGE=sqlite
# CANONICAL_SQLITE_PATH=/data/canonical.db
# MOLT_BUILD_CONTEXT=/opt/mywave/molt_http_service
# AGENTS_CONTROL_API_URL=https://agm.mywavewake.ru
# AGENTS_CONTROL_ENABLED=1
# MOLT_RUN_OWNER=0
# Start only with: docker compose ... -f docker-compose.molt.yml --profile molt up -d
RETENTION_DAYS=90
# EU-мост для Telegram из РФ (socks5/http на EU VPS):
# TELEGRAM_PROXY_URL=socks5://72.56.99.214:1080
# Подписанные ссылки на /tasks/{id} из Telegram (без X-API-Key в браузере)
# DASHBOARD_LINK_SECRET=  # опционально; иначе ключ = HMAC(OWNER_API_KEY, salt)
DASHBOARD_LINK_TTL_SECONDS=3600
# Runner (v0.2): для создания PR
# GH_TOKEN= или GITHUB_TOKEN=
# GITHUB_REPOSITORY=YaroslavValeev/mywave-ai-team
# MYWAVE_BASE_URL=https://agm.mywavewake.ru
